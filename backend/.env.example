DATABASE_URL=postgresql://user:password@pooler.neon.tech/dbname?sslmode=require

# REDIS - Redis Cloud 
REDIS_URL=redis://default:password@hostname:6379
# Or use cloud's CELERY_BROKER_URL if available
CELERY_BROKER_URL=redis://default:password@hostname:6379

# Local development fallback (ignored if REDIS_URL is set)
REDIS_HOST=localhost
REDIS_PORT=6379

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_BUCKET_NAME=streamscale-videos

VERCEL_FRONTEND_URL=https://your-frontend.vercel.app
# Alternative/generic frontend URL
FRONTEND_URL=https://your-frontend.vercel.app

